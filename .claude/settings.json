{
  "permissions": {
    "allow": [
      "Agent(architecture-reviewer)",
      "Agent(code-quality-reviewer)",
      "Agent(db-migration-reviewer)",
      "Agent(twada)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-dangerous-commands.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/plan-review.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/remind-branch-plan.sh"
          }
        ]
      }
    ]
  }
}
